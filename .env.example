# ─────────────────────────────────────────────────────────────
#  .env.example — Copy this to .env and fill in your values
#  NEVER commit your actual .env to GitHub!
# ─────────────────────────────────────────────────────────────

# ── Gemini API ────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Calendar ───────────────────────────────────────────
# The patient's Google Calendar ID (usually their Gmail address)
GOOGLE_CALENDAR_ID=patient@gmail.com

# ── Dify Secret ───────────────────────────────────────────────
# A random secret key for Dify's session signing
SECRET_KEY=change-this-to-a-random-string-at-least-32-chars

# ── Database ──────────────────────────────────────────────────
DB_PASSWORD=difypassword

# ── Timezone ──────────────────────────────────────────────────
# Set this to your local timezone (used by the scheduler)
# Examples: Asia/Kolkata, America/New_York, Europe/London
TZ=Asia/Kolkata
